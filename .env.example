# .env.example
#
# This is the committed reference file. It shows which environment variables
# the project needs WITHOUT containing any real secrets.
#
# How to use:
#   1. Copy this file to ".env" in the same folder:    cp .env.example .env
#   2. Fill in the real values in ".env" — never commit ".env".
#   3. Confirm ".env" is listed in .gitignore before your next commit.
#
# Rules:
#   - Never put a real key, token, or password in this file.
#   - Use UPPER_SNAKE_CASE for variable names.
#   - One variable per line, no spaces around the "=".
#   - Comment what each variable is for if the name isn't obvious.

# --- App config ---
NODE_ENV=development
PORT=3000

# --- Database (e.g., Supabase) ---
DATABASE_URL=postgres://user:password@host:5432/dbname
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Third-party APIs ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Integrations (delete the ones you don't use) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
GHL_API_KEY=
SLACK_WEBHOOK_URL=
